# Variáveis de ambiente do app web — referência.
# Em produção (Vercel), configure no dashboard: Settings → Environment Variables.
# Localmente, copie para apps/web/.env.local

# Supabase — Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URL base do app (sem barra no final)
# Local: http://localhost:3001
# Produção: https://assistencianet.vercel.app (ou domínio custom)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Evolution API — VM Oracle em produção, localhost em dev
# Local: http://localhost:8080
# Produção: http://129.148.55.107:8080 (IP público da VM)
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=
