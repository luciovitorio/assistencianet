# ============================================================
# App web (Next.js) — lido pelo container "web"
# ============================================================
NODE_ENV=production

# Supabase Cloud — pegar em https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Evolution API (usado pelo web para falar com o bot)
EVOLUTION_BASE_URL=http://evolution-api:8080
EVOLUTION_API_KEY=change-me-evolution-api-key

# ============================================================
# Postgres do Evolution — lido pelo container "evolution-postgres"
# (precisa ser igual em .env.evolution)
# ============================================================
POSTGRES_DATABASE=evolution_api
POSTGRES_USERNAME=evolution
POSTGRES_PASSWORD=change-me-postgres-password
